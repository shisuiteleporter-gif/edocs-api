# Credenciais da API do E-Docs
# Obtenha seu client_id e client_secret no Acesso Cidadao
# https://acessocidadao.es.gov.br
EDOCS_CLIENT_ID=seu-client-id-aqui
EDOCS_CLIENT_SECRET=seu-client-secret-aqui

# Ambiente: "treinamento" (padrao) ou "producao"
EDOCS_AMBIENTE=treinamento

# Escopos (separados por espaco)
# - api-sigades-consultar: consultas em geral
# - api-sigades-documento: upload, assinatura e captura de documentos
# - api-sigades-encaminhamento: criacao e resposta de encaminhamentos
# - api-sigades-processo: atos processuais (autuar, despachar, etc.)
EDOCS_SCOPE=api-sigades-consultar
